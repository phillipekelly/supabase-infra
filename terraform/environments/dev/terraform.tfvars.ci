# ==============================================================================
# Development Environment Variables
# Cost optimized — smaller instances, single AZ, minimal HA
# ==============================================================================

aws_region  = "us-east-1"
environment = "development"
project     = "supabase"

vpc_cidr             = "10.1.0.0/16"
availability_zones   = ["us-east-1a", "us-east-1b"]
private_subnet_cidrs = ["10.1.1.0/24", "10.1.2.0/24"]
public_subnet_cidrs  = ["10.1.101.0/24", "10.1.102.0/24"]

# Smaller instances for cost savings
eks_cluster_name       = "supabase-eks-dev"
eks_cluster_version    = "1.31"
eks_node_instance_type = "t3.small"
eks_node_min_size      = 2
eks_node_max_size      = 3
eks_node_desired_size  = 1

# Minimal DB for dev
db_name                  = "postgres"
db_master_username       = "supabase_admin"
db_instance_class        = "db.t4g.medium"
db_backup_retention_days = 7

storage_bucket_name = "supabase-storage-dev"

supabase_namespace = "supabase"
supabase_domain    = "dev-supabase.yourdomain.com"
studio_domain      = "dev-studio.yourdomain.com"
