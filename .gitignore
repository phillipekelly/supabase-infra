# ==============================================================================
# Secrets — never commit
# ==============================================================================
k8s/eso/secret-store-local.yaml
terraform/environments/*/terraform.tfvars

# ==============================================================================
# Terraform generated files
# ==============================================================================
# Downloaded providers and modules — regenerated by terraform init
**/.terraform/

# State files — stored in S3, never commit locally
*.tfstate
*.tfstate.backup

# Plan output files — never commit
*.tfplan

# ==============================================================================
# Helm chart dependencies — regenerated by helm dependency update
# ==============================================================================
helm/supabase-stack/charts/
helm/supabase-stack/Chart.lock

# ==============================================================================
# OS and editor
# ==============================================================================
.DS_Store
*.swp
*.swo
.idea/
.vscode/

# ==============================================================================
# Task description
# ==============================================================================
Instructions.txt
